<h1>Admin Dashboard</h1>

<h2>Actualités</h2>
<%= link_to 'New Blog', new_admin_blog_path %>
<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @blogs.each do |blog| %>
      <tr>
        <td><%= blog.title %></td>
        <td>
          <%= link_to 'Show', admin_blog_path(blog) %>
          <%= link_to 'Edit', edit_admin_blog_path(blog) %>
          <%= link_to 'Delete', admin_blog_path(blog), method: :delete, data: { confirm: 'Are you sure?' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2>Pending User Approvals</h2>
<table>
  <thead>
    <tr>
      <th>Full Name</th>
      <th>Email</th>
      <th>Company Name</th>
      <th>Function</th>
      <th>Phone</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @pending_users.each do |user| %>
      <tr>
        <td><%= user.full_name %></td>
        <td><%= user.email %></td>
        <td><%= user.company_name %></td>
        <td><%= user.function %></td>
        <td><%= user.phone %></td>
        <td>
          <%= link_to 'Approve', approve_admin_user_path(user), method: :patch, data: { confirm: 'Are you sure?' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2>Booking Management</h2>
<%= link_to 'New Booking', new_admin_booking_path %>
<table>
  <thead>
    <tr>
      <th>Booking ID</th>
      <th>Customer</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @bookings.each do |booking| %>
      <tr>
        <td><%= booking.id %></td>
        <td><%= booking.customer_name %></td>
        <td>
          <%= link_to 'Show', admin_booking_path(booking) %>
          <%= link_to 'Edit', edit_admin_booking_path(booking) %>
          <%= link_to 'Delete', admin_booking_path(booking), method: :delete, data: { confirm: 'Are you sure?' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2>Tracking Management</h2>
<%= link_to 'New Tracking', new_admin_tracking_path %>
<table>
  <thead>
    <tr>
      <th>Tracking ID</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @trackings.each do |tracking| %>
      <tr>
        <td><%= tracking.id %></td>
        <td><%= tracking.status %></td>
        <td>
          <%= link_to 'Show', admin_tracking_path(tracking) %>
          <%= link_to 'Edit', edit_admin_tracking_path(tracking) %>
          <%= link_to 'Delete', admin_tracking_path(tracking), method: :delete, data: { confirm: 'Are you sure?' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

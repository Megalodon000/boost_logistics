<!DOCTYPE html>
<html>
  <head>
    <title>Admin Dashboard</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag 'application', media: 'all' %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <main class="flex">
      <!-- Sidebar -->
      <aside class="w-1/4 bg-gray-800 text-white min-h-screen p-4">
        <h2 class="text-xl font-bold mb-4">Admin Dashboard</h2>
        <ul>
          <li class="mb-2">
            <%= link_to 'Blogs', '#', data: { controller: 'navigation', action: 'navigation#loadContent', section: 'blogs' }, class: "block p-2 rounded hover:bg-gray-600" %>
          </li>
          <li class="mb-2">
            <%= link_to 'Accounts', '#', data: { controller: 'navigation', action: 'navigation#loadContent', section: 'accounts' }, class: "block p-2 rounded hover:bg-gray-600" %>
          </li>
          <li class="mb-2">
            <%= link_to 'Bookings', '#', data: { controller: 'navigation', action: 'navigation#loadContent', section: 'bookings' }, class: "block p-2 rounded hover:bg-gray-600" %>
          </li>
          <li>
            <%= link_to 'Tracking', '#', data: { controller: 'navigation', action: 'navigation#loadContent', section: 'tracking' }, class: "block p-2 rounded hover:bg-gray-600" %>
          </li>
        </ul>
      </aside>

      <!-- Main Content -->
      <div id="content" class="w-3/4 p-4">
        <%= render 'blogs/index' %>
      </div>
    </main>
    <%= javascript_include_tag 'application' %>
  </body>
</html>

<!DOCTYPE html>
<html>
<head>
  <title>Boost Logistics Registration</title>
  <%= stylesheet_link_tag 'application', media: 'all' %>
  <%= javascript_include_tag 'application' %>
  <%= csrf_meta_tags %>
  <style>
    body {
      background: #f4f4f4; /* Light grey background */
      font-family: Arial, sans-serif;
      color: #333;
      margin: 0;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
    }
    .registration-container {
      background: #fff;
      padding: 20px;
      border-radius: 10px;
      width: 100%;
      max-width: 600px;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }
    .registration-container h2 {
      margin-bottom: 20px;
      text-align: center;
      color: #333;
    }
    .registration-container form {
      display: flex;
      flex-direction: column;
    }
    .registration-container form input,
    .registration-container form select {
      margin-bottom: 15px;
      padding: 10px;
      border: 1px solid #ccc;
      border-radius: 5px;
    }
    .registration-container form button {
      padding: 10px;
      border: none;
      border-radius: 5px;
      background: #007bff;
      color: #fff;
      cursor: pointer;
    }
    .registration-container form button:hover {
      background: #0056b3;
    }
  </style>
</head>
<body>
  <div class="registration-container">
    <h2>Boost Logistics Registration</h2>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= f.label :full_name, "Full Name" %>
      <%= f.text_field :full_name, autofocus: true, autocomplete: "name" %>

      <%= f.label :email %>
      <%= f.email_field :email, autocomplete: "email" %>

      <%= f.label :password %>
      <%= f.password_field :password, autocomplete: "new-password" %>

      <%= f.label :password_confirmation, "Confirm Password" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password" %>

      <%= f.label :company_name, "Company Name" %>
      <%= f.text_field :company_name %>

      <%= f.label :function, "Choose Your Job Role" %>
      <%= f.select :function, options_for_select([
        ['CEO', 'ceo'],
        ['Department Management', 'department_management'],
        ['Middle Management', 'middle_management'],
        ['Junior Executive', 'junior_executive'],
        ['Consultants and Advisors', 'consultants_advisors'],
        ['Key Account/ Supplier Management', 'key_account_supplier_management']
      ]) %>

      <%= f.label :phone, "Phone" %>
      <%= f.telephone_field :phone %>

      <%= f.label :address, "Address (optional)" %>
      <%= f.text_field :address %>

      <%= f.label :city, "City (optional)" %>
      <%= f.text_field :city %>

      <%= f.label :country, "Country" %>
      <%= f.text_field :country %>

      <%= f.submit "Register", class: 'btn btn-primary' %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</body>
</html>

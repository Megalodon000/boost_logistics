<h1>Bookings</h1>

<%= link_to 'New Booking', new_admin_booking_path %>
<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Origin</th>
      <th>Destination</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @bookings.each do |booking| %>
      <tr>
        <td><%= booking.id %></td>
        <td><%= booking.origin %></td>
        <td><%= booking.destination %></td>
        <td>
          <%= link_to 'Show', admin_booking_path(booking) %>
          <%= link_to 'Edit', edit_admin_booking_path(booking) %>
          <%= link_to 'Delete', admin_booking_path(booking), method: :delete, data: { confirm: 'Are you sure?' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

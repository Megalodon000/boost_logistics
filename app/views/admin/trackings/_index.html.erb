<h2 class="text-2xl font-bold mb-4">Trackings</h2>
<table class="min-w-full bg-white">
  <thead>
    <tr>
      <th class="py-2 px-4 border-b">Tracking ID</th>
      <th class="py-2 px-4 border-b">Status</th>
      <th class="py-2 px-4 border-b">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @trackings.each do |tracking| %>
      <tr>
        <td class="py-2 px-4 border-b"><%= tracking.id %></td>
        <td class="py-2 px-4 border-b"><%= tracking.status %></td>
        <td class="py-2 px-4 border-b">
          <%= link_to 'Show', admin_tracking_path(tracking), class: 'text-blue-500 hover:underline' %>
          <%= link_to 'Edit', edit_admin_tracking_path(tracking), class: 'text-blue-500 hover:underline' %>
          <%= link_to 'Delete', admin_tracking_path(tracking), method: :delete, data: { confirm: 'Are you sure?' }, class: 'text-red-500 hover:underline' %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
